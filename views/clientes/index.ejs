<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>
            
            <div class="col py-0 py-md-3 main-content-wrapper">
                <%- include('../partials/mobile-header') %>
                
                <div class="container-fluid px-4 py-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                        <h2>👥 Listado de Clientes</h2>
                        <a href="/clientes/crear" class="btn btn-primary">
                            <i class="bi bi-person-plus"></i> Nuevo Cliente
                        </a>
                    </div>

                    <% if(mensajeExito && mensajeExito.length > 0) { %>
                        <div class="d-none" id="flashMessageSuccess"><%= mensajeExito %></div>
                    <% } %>
                    <% if(mensajeError && mensajeError.length > 0) { %>
                        <div class="alert alert-danger"><%= mensajeError %></div>
                    <% } %>

                    <div class="card card-box p-3 mb-4 bg-light">
                        <form action="/clientes" method="GET" class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label class="col-form-label fw-bold"><i class="bi bi-search"></i> Buscar:</label>
                            </div>
                            <div class="col-auto flex-grow-1">
                                <input type="text" name="q" class="form-control" placeholder="Nombre, Apellido o CC..." value="<%= busqueda %>">
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-dark">Filtrar</button>
                                <% if(busqueda) { %>
                                    <a href="/clientes" class="btn btn-outline-secondary">Limpiar</a>
                                <% } %>
                            </div>
                        </form>
                    </div>

                    <div class="card card-box p-3">
                        <div class="table-responsive" style="min-height: 300px;">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Foto</th>
                                        <th>CC</th>
                                        <th>Cliente</th>
                                        <th>Contacto</th>
                                        <th class="text-center">Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (clientes.length > 0) { %>
                                        <% clientes.forEach(cliente => { %>
                                            <tr>
                                                <td>
                                                    <% if(cliente.foto) { %>
                                                        <img src="/uploads/<%= cliente.foto %>" class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;">
                                                    <% } else { %>
                                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                            <%= cliente.nombre.charAt(0) %>
                                                        </div>
                                                    <% } %>
                                                </td>
                                                <td><span class="badge bg-light text-dark border"><%= cliente.dni %></span></td>
                                                <td>
                                                    <div class="fw-bold"><%= cliente.nombre %> <%= cliente.apellido %></div>
                                                    <small class="text-muted"><%= cliente.direccion || 'Sin dirección' %></small>
                                                </td>
                                                <td>
                                                    <div class="small"><i class="bi bi-telephone"></i> <%= cliente.telefono || '-' %></div>
                                                    <div class="small text-muted"><i class="bi bi-envelope"></i> <%= cliente.email || '-' %></div>
                                                </td>
                                                <td class="text-center">
                                                    <% if(cliente.estado == 1 || cliente.estado == null) { %>
                                                        <span class="badge bg-success bg-opacity-75 rounded-pill">Activo</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary rounded-pill">Inactivo</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <div class="btn-group">
                                                        <button type="button" class="btn btn-sm btn-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-bs-boundary="viewport">
                                                            Opciones
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end shadow">
                                                            <li><a class="dropdown-item" href="/clientes/ver/<%= cliente.id %>"><i class="bi bi-eye-fill text-info me-2"></i> Ver Perfil</a></li>
                                                            <li><a class="dropdown-item" href="/clientes/editar/<%= cliente.id %>"><i class="bi bi-pencil-fill text-warning me-2"></i> Editar</a></li>
                                                            <li><hr class="dropdown-divider"></li>
                                                            
                                                            <% if(cliente.estado == 1 || cliente.estado == null) { %>
                                                                <li>
                                                                    <a class="dropdown-item text-danger" href="/clientes/cambiar-estado/<%= cliente.id %>" 
                                                                       onclick="confirmarCambioEstado(event, this.href, 'bloquear', 'cliente')">
                                                                        <i class="bi bi-lock-fill me-2"></i> Inhabilitar
                                                                    </a>
                                                                </li>
                                                            <% } else { %>
                                                                <li>
                                                                    <a class="dropdown-item text-success" href="/clientes/cambiar-estado/<%= cliente.id %>" 
                                                                       onclick="confirmarCambioEstado(event, this.href, 'activar', 'cliente')">
                                                                        <i class="bi bi-unlock-fill me-2"></i> Habilitar
                                                                    </a>
                                                                </li>
                                                            <% } %>
                                                        </ul>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="6" class="text-center py-5">No se encontraron clientes.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                        
                        <% if (totalPages > 1) { %>
                            <nav class="mt-4 d-flex justify-content-between align-items-center">
                                <small class="text-muted">Página <%= currentPage %> de <%= totalPages %></small>
                                <ul class="pagination mb-0">
                                    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="/clientes?page=<%= currentPage - 1 %>&q=<%= busqueda %>">Anterior</a>
                                    </li>
                                    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="/clientes?page=<%= currentPage + 1 %>&q=<%= busqueda %>">Siguiente</a>
                                    </li>
                                </ul>
                            </nav>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include('../partials/footer') %>
