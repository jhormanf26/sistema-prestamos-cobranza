<!DOCTYPE html>
<html lang="es">
<%- include('partials/head') %>
<style>
    .info-tile {
        transition: all 0.3s ease;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #f1f5f9;
    }
    .info-tile:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        border-color: #e2e8f0;
    }
    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
    }
    .licencia-header {
        border-radius: 24px;
        position: relative;
        overflow: hidden;
    }
    .glow-icon {
        position: relative;
        z-index: 2;
    }
    .glow-effect {
        position: absolute;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0.6;
        z-index: 1;
    }
    .btn-premium {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-weight: 700;
        transition: all 0.3s ease;
    }
    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.4);
    }
</style>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('partials/sidebar') %>

            <div class="col py-0 py-md-3 main-content-wrapper">
                <%- include('partials/mobile-header') %>

                <div class="container-fluid px-4 py-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h4 class="mb-1 fw-bold"><i class="bi bi-shield-check text-primary me-2"></i>Gestión de Licencia</h4>
                            <p class="text-muted small mb-0">Control de vigencia y activación del sistema profesional</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- LADO IZQUIERDO: ESTADO Y DETALLES -->
                        <div class="col-lg-8">
                            
                            <!-- TARJETA DE ESTADO PREMIUM -->
                            <div class="card licencia-header bg-gradient-premium border-0 shadow-lg mb-4">
                                <div class="card-body p-5">
                                    <div class="row align-items-center">
                                        <div class="col-md-7">
                                            <small class="text-uppercase text-white-50 fw-bold mb-2 d-block" style="letter-spacing: 2px;">Estado Actual</small>
                                            
                                            <% if (licenciaInfo.estadoClase === 'activa') { %>
                                                <h1 class="text-white fw-800 mb-2 display-5">Licencia Activa</h1>
                                                <p class="text-white-50 mb-4">Su sistema está operando con total normalidad y protección.</p>
                                                <div class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-50 px-3 py-2 rounded-pill">
                                                    <i class="bi bi-check-circle-fill me-2"></i> Protegido
                                                </div>
                                            <% } else if (licenciaInfo.estadoClase === 'por-vencer') { %>
                                                <h1 class="text-warning fw-800 mb-2 display-5">Próxima a Vencer</h1>
                                                <p class="text-white-50 mb-4 text-warning">¡Atención! Su periodo de vigencia está por terminar.</p>
                                                <div class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-50 px-3 py-2 rounded-pill shadow-glow-warning">
                                                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Acción requerida
                                                </div>
                                            <% } else { %>
                                                <h1 class="text-danger fw-800 mb-2 display-5">Sistema Bloqueado</h1>
                                                <p class="text-white-50 mb-4">La licencia ha expirado. Por favor, renueve su acceso.</p>
                                                <div class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-50 px-3 py-2 rounded-pill shadow-glow-danger">
                                                    <i class="bi bi-shield-lock-fill me-2"></i> Sin Protección
                                                </div>
                                            <% } %>

                                            <div class="mt-5 row g-3">
                                                <div class="col-6">
                                                    <div class="glass-card p-3 rounded-4">
                                                        <small class="text-white fw-bold d-block mb-1 opacity-75">VIGENCIA HASTA</small>
                                                        <span class="text-white fw-bold fs-5"><%= licenciaInfo.fechaVencimiento || 'N/A' %></span>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="glass-card p-3 rounded-4">
                                                        <small class="text-white fw-bold d-block mb-1 opacity-75">DÍAS RESTANTES</small>
                                                        <span class="fw-bold fs-5 <%= licenciaInfo.diasRestantes > 7 ? 'text-success' : 'text-warning' %>">
                                                            <%= licenciaInfo.diasRestantes %> Días
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-5 d-none d-md-flex justify-content-center position-relative">
                                            <% 
                                                let glowColor = '#22c55e';
                                                let iconClass = 'bi-shield-check text-success';
                                                if(licenciaInfo.estadoClase === 'por-vencer') { glowColor = '#f59e0b'; iconClass = 'bi-shield-exclamation text-warning'; }
                                                if(licenciaInfo.estadoClase === 'expirada') { glowColor = '#ef4444'; iconClass = 'bi-shield-x text-danger'; }
                                            %>
                                            <div class="glow-effect" style="background: <%= glowColor %>;"></div>
                                            <i class="bi <%= iconClass %> glow-icon" style="font-size: 140px; filter: drop-shadow(0 0 20px <%= glowColor %>44);"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- GRID DE DETALLES (TILES) -->
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="info-tile p-4 h-100 shadow-sm border-0">
                                        <div class="icon-box bg-primary bg-opacity-10 text-primary">
                                            <i class="bi bi-building fs-4"></i>
                                        </div>
                                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">RUC Empresa</small>
                                        <div class="fw-bold fs-6 text-dark"><%= licenciaInfo.ruc %></div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="info-tile p-4 h-100 shadow-sm border-0">
                                        <div class="icon-box bg-purple bg-opacity-10 text-purple" style="color: #8b5cf6;">
                                            <i class="bi bi-hash fs-4"></i>
                                        </div>
                                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">ID de Registro</small>
                                        <div class="fw-bold fs-6 text-dark">#<%= licenciaInfo.empresaId %></div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="info-tile p-4 h-100 shadow-sm border-0">
                                        <div class="icon-box bg-info bg-opacity-10 text-info">
                                            <i class="bi bi-tag fs-4"></i>
                                        </div>
                                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Versión del Sistema</small>
                                        <div class="fw-bold fs-6 text-dark"><%= licenciaInfo.tipo %> (PRO)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LADO DERECHO: RENOVACIÓN -->
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-lg rounded-4 overflow-hidden h-100">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-4">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                                            <i class="bi bi-arrow-repeat fs-4"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-0 fw-bold">Renovación</h5>
                                            <small class="text-muted">Cargar nueva licencia RSA</small>
                                        </div>
                                    </div>

                                    <form action="/mi-licencia/renovar" method="POST">
                                        <div class="mb-4">
                                            <label class="form-label fw-600 text-dark small mb-2">TOKEN DE ACTIVACIÓN (BASE64)</label>
                                            <textarea 
                                                class="form-control border-1 bg-white rounded-4 font-monospace p-3 shadow-sm" 
                                                name="token_licencia" 
                                                rows="8" 
                                                placeholder="Pegue aquí el código provisto por su proveedor..."
                                                style="font-size: 13px; resize: none; border: 1px solid #e2e8f0;"
                                                required
                                            ></textarea>
                                        </div>

                                        <button type="submit" class="btn btn-premium w-100 text-white flex-nowrap d-flex align-items-center justify-content-center">
                                            <i class="bi bi-shield-fill-check me-2"></i> ACTUALIZAR SISTEMA
                                        </button>
                                    </form>

                                    <div class="mt-4 p-3 bg-light rounded-4 d-flex gap-3 align-items-start border border-dashed border-secondary border-opacity-25">
                                        <i class="bi bi-info-circle-fill text-primary"></i>
                                        <p class="small text-muted mb-0">Esta licencia opera <strong>100% Offline</strong> y se verifica localmente para su seguridad.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<%- include('partials/footer') %>
</body>
</html>
