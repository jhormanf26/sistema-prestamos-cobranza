<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('../partials/sidebar') %>

                    <div class="col py-0 py-md-3 main-content-wrapper">
                        <%- include('../partials/mobile-header') %>
                            <div class="container-fluid px-4 py-4">

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h2 class="fw-bold"><i class="bi bi-shield-lock-fill text-warning"></i> Gestión de
                                        Usuarios</h2>
                                    <a href="/usuarios/crear" class="btn btn-dark">
                                        <i class="bi bi-person-plus-fill me-2"></i> Nuevo Usuario
                                    </a>
                                </div>

                                <% if(mensajeExito && mensajeExito.length> 0) { %>
                                    <div class="d-none" id="flashMessageSuccess">
                                        <%= mensajeExito %>
                                    </div>
                                    <% } %>
                                        <% if(mensajeError && mensajeError.length> 0) { %>
                                            <div class="alert alert-danger shadow-sm border-0">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                <%= mensajeError %>
                                            </div>
                                            <% } %>

                                                <div class="card border-0 shadow-sm">
                                                    <div class="card-body p-0">
                                                        <div class="table-responsive">
                                                            <table class="table table-hover align-middle mb-0">
                                                                <thead class="bg-light">
                                                                    <tr>
                                                                        <th
                                                                            class="ps-4 text-uppercase text-muted small fw-bold">
                                                                            ID</th>
                                                                        <th
                                                                            class="text-uppercase text-muted small fw-bold">
                                                                            Nombre</th>
                                                                        <th
                                                                            class="text-uppercase text-muted small fw-bold">
                                                                            Email</th>
                                                                        <th
                                                                            class="text-uppercase text-muted small fw-bold">
                                                                            Rol</th>
                                                                        <th
                                                                            class="text-center text-uppercase text-muted small fw-bold">
                                                                            Estado</th>
                                                                        <th
                                                                            class="text-end pe-4 text-uppercase text-muted small fw-bold">
                                                                            Acciones</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <% if (usuarios.length> 0) { %>
                                                                        <% usuarios.forEach(u=> { %>
                                                                            <tr>
                                                                                <td class="ps-4 fw-bold text-muted">#<%=
                                                                                        u.id %>
                                                                                </td>
                                                                                <td>
                                                                                    <span class="fw-bold text-dark">
                                                                                        <%= u.nombre_completo %>
                                                                                    </span>
                                                                                </td>
                                                                                <td class="text-muted">
                                                                                    <%= u.email %>
                                                                                </td>
                                                                                <td>
                                                                                    <% if(u.rol==='admin' ) { %>
                                                                                        <span
                                                                                            class="badge bg-danger">Administrador</span>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="badge bg-primary">Empleado</span>
                                                                                            <% } %>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <% if(u.estado==1) { %>
                                                                                        <span
                                                                                            class="badge bg-success bg-opacity-75 rounded-pill px-3">Activo</span>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="badge bg-secondary rounded-pill px-3">Inactivo</span>
                                                                                            <% } %>
                                                                                </td>
                                                                                <td class="text-end pe-4">
                                                                                    <% if (usuario.id !=u.id) { %>

                                                                                        <% if (u.estado==1) { %>
                                                                                            <a href="/usuarios/cambiar-estado/<%= u.id %>"
                                                                                                class="btn btn-sm btn-outline-secondary"
                                                                                                title="Desactivar acceso"
                                                                                                onclick="confirmarCambioEstado(event, this.href, 'bloquear', 'usuario')">
                                                                                                <i
                                                                                                    class="bi bi-lock-fill"></i>
                                                                                                Bloquear
                                                                                            </a>
                                                                                            <% } else { %>
                                                                                                <a href="/usuarios/cambiar-estado/<%= u.id %>"
                                                                                                    class="btn btn-sm btn-outline-success"
                                                                                                    title="Restaurar acceso"
                                                                                                    onclick="confirmarCambioEstado(event, this.href, 'activar', 'usuario')">
                                                                                                    <i
                                                                                                        class="bi bi-unlock-fill"></i>
                                                                                                    Activar
                                                                                                </a>
                                                                                                <% } %>

                                                                                                    <% } else { %>
                                                                                                        <span
                                                                                                            class="text-muted small fst-italic">(Tu
                                                                                                            cuenta)</span>
                                                                                                        <% } %>
                                                                                </td>
                                                                            </tr>
                                                                            <% }) %>
                                                                                <% } else { %>
                                                                                    <tr>
                                                                                        <td colspan="6"
                                                                                            class="text-center py-5 text-muted">
                                                                                            No hay usuarios registrados.
                                                                                        </td>
                                                                                    </tr>
                                                                                    <% } %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>

                            </div>
                    </div>
            </div>
        </div>
        <%- include('../partials/footer') %>