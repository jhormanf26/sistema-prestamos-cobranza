<!DOCTYPE html>
<html lang="es">
<%- include('partials/head') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('partials/sidebar') %>

                    <div class="col py-0 py-md-3 main-content-wrapper">
                        <%- include('partials/mobile-header') %>

                            <div class="container-fluid px-4 py-4">
                                <h2 class="mb-4 d-none d-md-block">Panel de Control</h2>

                                <!-- Fila 1: KPI Principales -->
                                <div class="row g-4 mb-4">
                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-primary h-100 border-0">
                                            <div>
                                                <h5>Clientes</h5>
                                                <h3><%= totales.clientes %></h3>
                                                <small>Registrados</small>
                                            </div>
                                            <i class="bi bi-people"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-success h-100 border-0">
                                            <div>
                                                <h5>Capital Pendiente</h5>
                                                <h3><%= empresa.moneda %> <%= parseFloat(totales.dineroPrestado).toLocaleString('en-US', {minimumFractionDigits: 2}) %></h3>
                                                <small>Dinero en calle</small>
                                            </div>
                                            <i class="bi bi-cash-stack"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-purple h-100 border-0">
                                            <div>
                                                <h5>Fondos / Ahorros</h5>
                                                <h3><%= empresa.moneda %> <%= parseFloat(totales.totalAhorros).toLocaleString('en-US', {minimumFractionDigits: 2}) %></h3>
                                                <small>Capital Captado</small>
                                            </div>
                                            <i class="bi bi-piggy-bank"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-info h-100 border-0">
                                            <div>
                                                <h5>Total Cobrado</h5>
                                                <h3><%= empresa.moneda %> <%= parseFloat(totales.dineroCobrado).toLocaleString('en-US', {minimumFractionDigits: 2}) %></h3>
                                                <small>Histórico</small>
                                            </div>
                                            <i class="bi bi-wallet2"></i>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 2: Indicadores de Mora y Riesgo -->
                                <div class="row g-4 mb-5">
                                    <div class="col-md-6 col-lg-3">
                                        <div class="card card-box border-start border-danger border-4 shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="text-muted text-uppercase small">Clientes en Mora</h6>
                                                        <h4 class="fw-bold text-danger mb-0"><%= totales.clientesMora %></h4>
                                                    </div>
                                                    <div class="bg-danger-subtle p-3 rounded-circle">
                                                        <i class="bi bi-exclamation-triangle-fill text-danger fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="mt-2 text-danger small"><i class="bi bi-info-circle"></i> Fecha vencida</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-lg-3">
                                        <div class="card card-box border-start border-warning border-4 shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="text-muted text-uppercase small">Monto en Riesgo</h6>
                                                        <h4 class="fw-bold text-warning mb-0">
                                                            <%= empresa.moneda %> <%= parseFloat(totales.montoEnRiesgo).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                                                        </h4>
                                                    </div>
                                                    <div class="bg-warning-subtle p-3 rounded-circle">
                                                        <i class="bi bi-shield-lock-fill text-warning fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="mt-2 text-warning small"><i class="bi bi-graph-down"></i> Capital por recuperar</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 3: Gráficos -->
                                <div class="row g-4 mb-5">
                                    <div class="col-lg-5"><div class="card card-box shadow-sm border-0 h-100"><div class="card-header bg-white fw-bold">Estado de la Cartera</div><div class="card-body"><div style="height: 300px;"><canvas id="chartEstados"></canvas></div></div></div></div>
                                    <div class="col-lg-7"><div class="card card-box shadow-sm border-0 h-100"><div class="card-header bg-white fw-bold">Balance: Prestado vs Recuperado</div><div class="card-body"><div style="height: 300px;"><canvas id="chartBalance"></canvas></div></div></div></div>
                                </div>

                                <!-- Fila 4: Tablas de Gestión Operativa -->
                                <div class="row g-4 mb-5">
                                    <div class="col-lg-6">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                                                <span>🚨 Clientes en Mora Detallado</span>
                                                <span class="badge bg-danger"><%= detalleMora.length %> Registros</span>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0 text-nowrap">
                                                        <thead class="table-light"><tr><th class="ps-3">Cliente</th><th>Venció el</th><th>Saldo</th><th class="text-end pe-3">Acción</th></tr></thead>
                                                        <tbody>
                                                            <% if(detalleMora.length > 0) { detalleMora.forEach(m => { %>
                                                                <tr>
                                                                    <td class="ps-3"><span class="fw-bold d-block"><%= m.nombre %> <%= m.apellido %></span><small class="text-muted"><%= m.telefono %></small></td>
                                                                    <td><span class="badge bg-danger-subtle text-danger"><%= new Date(m.fecha_fin).toLocaleDateString() %></span></td>
                                                                    <td class="fw-bold text-dark"><%= empresa.moneda %> <%= parseFloat(m.monto_total).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                                                                    <td class="text-end pe-3"><a href="/pagos/registrar/<%= m.id %>" class="btn btn-sm btn-success">Cobrar</a></td>
                                                                </tr>
                                                            <% }) } else { %><tr><td colspan="4" class="text-center py-4 text-muted">No hay clientes en mora</td></tr><% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-6">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                                                <span>📅 Próximos Vencimientos (7 días)</span>
                                                <span class="badge bg-warning text-dark"><%= proximosVencimientos.length %> Registros</span>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0 text-nowrap">
                                                        <thead class="table-light"><tr><th class="ps-3">Cliente</th><th>Vence el</th><th>Cuotas</th><th class="text-end pe-3">Acción</th></tr></thead>
                                                        <tbody>
                                                            <% if(proximosVencimientos.length > 0) { proximosVencimientos.forEach(v => { %>
                                                                <tr>
                                                                    <td class="ps-3"><span class="fw-bold d-block"><%= v.nombre %> <%= v.apellido %></span><small class="text-muted"><%= v.frecuencia %></small></td>
                                                                    <td><span class="badge bg-info-subtle text-info"><%= new Date(v.fecha_fin).toLocaleDateString() %></span></td>
                                                                    <td class="fw-bold"><%= v.cuotas %> Cuotas</td>
                                                                    <td class="text-end pe-3"><a href="/prestamos/ver/<%= v.id %>" class="btn btn-sm btn-outline-primary">Ver</a></td>
                                                                </tr>
                                                            <% }) } else { %><tr><td colspan="4" class="text-center py-4 text-muted">No hay vencimientos próximos</td></tr><% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 5: Historial de Clientes Finalizados -->
                                <div class="row mb-5">
                                    <div class="col-12">
                                        <div class="card card-box shadow-sm border-0">
                                            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center py-3">
                                                <div class="d-flex align-items-center"><i class="bi bi-journal-check fs-4 me-2 text-success"></i><span class="fs-5">Historial Crediticio: Préstamos Finalizados</span></div>
                                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3">Top 10 Clientes</span>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0 text-nowrap">
                                                        <thead class="table-dark">
                                                            <tr>
                                                                <th class="ps-4">Cliente</th>
                                                                <th class="text-center">Préstamos <br> Pagados</th>
                                                                <th class="text-center bg-primary-subtle text-primary border-start border-end">Capital Mín.</th>
                                                                <th class="text-center bg-primary-subtle text-primary">Capital Máx.</th>
                                                                <th class="text-center bg-warning-subtle text-dark border-start border-end">Tasa Mín. (%)</th>
                                                                <th class="text-center bg-warning-subtle text-dark">Tasa Máx. (%)</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% if(historialFinalizados && historialFinalizados.length > 0) { historialFinalizados.forEach(h => { %>
                                                                <tr>
                                                                    <td class="ps-4 py-3">
                                                                        <div class="d-flex align-items-center">
                                                                            <div class="avatar-circle-sm bg-light text-primary fw-bold me-3 text-center" style="width: 35px; height: 35px; line-height: 35px; border-radius: 50%;"><%= h.nombre.charAt(0) %></div>
                                                                            <div><span class="fw-bold d-block"><%= h.nombre %> <%= h.apellido %></span><small class="text-muted"><%= h.telefono %></small></div>
                                                                        </div>
                                                                    </td>
                                                                    <td class="text-center"><span class="badge rounded-pill bg-dark px-3 fs-6"><%= h.total_prestamos %></span></td>
                                                                    <td class="text-center border-start"><%= empresa.moneda %> <%= parseFloat(h.capital_min).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                                                                    <td class="text-center border-end fw-bold text-primary"><%= empresa.moneda %> <%= parseFloat(h.capital_max).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                                                                    <!-- Tasas en % -->
                                                                    <td class="text-center bg-light"><%= parseFloat(h.interes_min_pct).toFixed(1) %>%</td>
                                                                    <td class="text-center bg-light fw-bold text-warning-emphasis"><%= parseFloat(h.interes_max_pct).toFixed(1) %>%</td>
                                                                </tr>
                                                            <% }) } else { %><tr><td colspan="6" class="text-center py-5 text-muted">Aún no hay clientes con préstamos finalizados.</td></tr><% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                    </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            const datosEstados = <%- JSON.stringify(graficos.estados) %>;
            const datosBalance = <%- JSON.stringify(graficos.balance) %>;
            const moneda = "<%= empresa.moneda %>";
            new Chart(document.getElementById('chartEstados').getContext('2d'), { type: 'doughnut', data: { labels: ['Pendiente', 'Pagado', 'Vencido'], datasets: [{ data: datosEstados, backgroundColor: ['#ffc107', '#198754', '#dc3545'], borderWidth: 2 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } } });
            new Chart(document.getElementById('chartBalance').getContext('2d'), { type: 'bar', data: { labels: ['Total Prestado (Histórico)', 'Total Recuperado'], datasets: [{ label: `Monto en ${moneda}`, data: datosBalance, backgroundColor: ['#0d6efd', '#0dcaf0'], borderWidth: 1 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
        </script>
        <%- include('partials/footer') %>