<!DOCTYPE html>
<html lang="es">
<%- include('partials/head') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('partials/sidebar') %>

                    <div class="col py-0 py-md-3 main-content-wrapper">
                        <%- include('partials/mobile-header') %>

                            <div class="container-fluid px-4 py-4">
                                <h2 class="mb-4 d-none d-md-block">Panel de Control</h2>

                                <!-- Fila 1: KPI Principales -->
                                <div class="row g-4 mb-4">
                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-primary h-100 border-0">
                                            <div>
                                                <h5>Clientes</h5>
                                                <h3>
                                                    <%= totales.clientes %>
                                                </h3>
                                                <small>Registrados</small>
                                            </div>
                                            <i class="bi bi-people"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-success h-100 border-0">
                                            <div>
                                                <h5>Capital Pendiente</h5>
                                                <h3>
                                                    <%= empresa.moneda %>
                                                        <%= parseFloat(totales.dineroPrestado).toLocaleString('en-US',
                                                            {minimumFractionDigits: 2}) %>
                                                </h3>
                                                <small>Dinero en calle</small>
                                            </div>
                                            <i class="bi bi-cash-stack"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-purple h-100 border-0">
                                            <div>
                                                <h5>Fondos / Ahorros</h5>
                                                <h3>
                                                    <%= empresa.moneda %>
                                                        <%= parseFloat(totales.totalAhorros).toLocaleString('en-US',
                                                            {minimumFractionDigits: 2}) %>
                                                </h3>
                                                <small>Capital Captado</small>
                                            </div>
                                            <i class="bi bi-piggy-bank"></i>
                                        </div>
                                    </div>

                                    <div class="col-12 col-sm-6 col-xl">
                                        <div class="card card-box stat-card stat-card-info h-100 border-0">
                                            <div>
                                                <h5>Total Cobrado</h5>
                                                <h3>
                                                    <%= empresa.moneda %>
                                                        <%= parseFloat(totales.dineroCobrado).toLocaleString('en-US',
                                                            {minimumFractionDigits: 2}) %>
                                                </h3>
                                                <small>Histórico</small>
                                            </div>
                                            <i class="bi bi-wallet2"></i>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 2: Indicadores de Mora y Riesgo -->
                                <div class="row g-4 mb-5">
                                    <div class="col-md-6 col-lg-3">
                                        <div class="card card-box border-start border-danger border-4 shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="text-muted text-uppercase small">Clientes en Mora
                                                        </h6>
                                                        <h4 class="fw-bold text-danger mb-0">
                                                            <%= totales.clientesMora %>
                                                        </h4>
                                                    </div>
                                                    <div class="bg-danger-subtle p-3 rounded-circle">
                                                        <i class="bi bi-exclamation-triangle-fill text-danger fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="mt-2 text-danger small">
                                                    <i class="bi bi-info-circle"></i> Fecha vencida
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-lg-3">
                                        <div class="card card-box border-start border-warning border-4 shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="text-muted text-uppercase small">Monto en Riesgo</h6>
                                                        <h4 class="fw-bold text-warning mb-0">
                                                            <%= empresa.moneda %>
                                                                <%= parseFloat(totales.montoEnRiesgo).toLocaleString('en-US',
                                                                    {minimumFractionDigits: 2}) %>
                                                        </h4>
                                                    </div>
                                                    <div class="bg-warning-subtle p-3 rounded-circle">
                                                        <i class="bi bi-shield-lock-fill text-warning fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="mt-2 text-warning small">
                                                    <i class="bi bi-graph-down"></i> Capital por recuperar
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 3: Gráficos -->
                                <div class="row g-4 mb-5">
                                    <div class="col-lg-5">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold">Estado de la Cartera</div>
                                            <div class="card-body">
                                                <div style="height: 300px;">
                                                    <canvas id="chartEstados"></canvas>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-7">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold">Balance: Prestado vs Recuperado
                                            </div>
                                            <div class="card-body">
                                                <div style="height: 300px;">
                                                    <canvas id="chartBalance"></canvas>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fila 4: Tablas de Detalles (NUEVO) -->
                                <div class="row g-4 mb-5">
                                    <!-- Clientes en Mora -->
                                    <div class="col-lg-6">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                                                <span>🚨 Clientes en Mora Detallado</span>
                                                <span class="badge bg-danger"><%= detalleMora.length %> Registros</span>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th class="ps-3">Cliente</th>
                                                                <th>Venció el</th>
                                                                <th>Saldo</th>
                                                                <th class="text-end pe-3">Acción</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% if(detalleMora.length > 0) { %>
                                                                <% detalleMora.forEach(m => { %>
                                                                    <tr>
                                                                        <td class="ps-3">
                                                                            <span class="fw-bold d-block"><%= m.nombre %> <%= m.apellido %></span>
                                                                            <small class="text-muted"><%= m.telefono %></small>
                                                                        </td>
                                                                        <td><span class="badge bg-danger-subtle text-danger"><%= new Date(m.fecha_fin).toLocaleDateString() %></span></td>
                                                                        <td class="fw-bold text-dark"><%= empresa.moneda %> <%= parseFloat(m.monto_total).toLocaleString('en-US', {minimumFractionDigits: 2}) %></td>
                                                                        <td class="text-end pe-3">
                                                                            <a href="/pagos/registrar/<%= m.id %>" class="btn btn-sm btn-success">Cobrar</a>
                                                                        </td>
                                                                    </tr>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <tr><td colspan="4" class="text-center py-4 text-muted">No hay clientes en mora</td></tr>
                                                            <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Próximos Vencimientos -->
                                    <div class="col-lg-6">
                                        <div class="card card-box shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                                                <span>📅 Próximos Vencimientos (7 días)</span>
                                                <span class="badge bg-warning text-dark"><%= proximosVencimientos.length %> Registros</span>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th class="ps-3">Cliente</th>
                                                                <th>Vence el</th>
                                                                <th>Cuotas</th>
                                                                <th class="text-end pe-3">Acción</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% if(proximosVencimientos.length > 0) { %>
                                                                <% proximosVencimientos.forEach(v => { %>
                                                                    <tr>
                                                                        <td class="ps-3">
                                                                            <span class="fw-bold d-block"><%= v.nombre %> <%= v.apellido %></span>
                                                                            <small class="text-muted"><%= v.frecuencia %></small>
                                                                        </td>
                                                                        <td><span class="badge bg-info-subtle text-info"><%= new Date(v.fecha_fin).toLocaleDateString() %></span></td>
                                                                        <td class="fw-bold"><%= v.cuotas %> Cuotas</td>
                                                                        <td class="text-end pe-3">
                                                                            <a href="/prestamos/ver/<%= v.id %>" class="btn btn-sm btn-outline-primary">Ver</a>
                                                                        </td>
                                                                    </tr>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <tr><td colspan="4" class="text-center py-4 text-muted">No hay vencimientos próximos</td></tr>
                                                            <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h4 class="text-secondary">Accesos Rápidos</h4>
                                        <hr>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <a href="/prestamos/crear"
                                            class="btn btn-outline-primary w-100 p-4 text-start hover-shadow bg-white">
                                            <div class="d-flex align-items-center"><i
                                                    class="bi bi-plus-circle fs-1 me-3"></i>
                                                <div><span class="fw-bold fs-5 d-block">Nuevo Préstamo</span><small
                                                        class="text-muted">Registrar salida de dinero</small></div>
                                            </div>
                                        </a>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <a href="/empenos/crear"
                                            class="btn btn-outline-warning text-dark w-100 p-4 text-start hover-shadow bg-white">
                                            <div class="d-flex align-items-center"><i
                                                    class="bi bi-box-seam fs-1 me-3"></i>
                                                <div><span class="fw-bold fs-5 d-block">Nuevo Empeño</span><small
                                                        class="text-muted">Registrar entrada de garantía</small></div>
                                            </div>
                                        </a>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <a href="/clientes/crear"
                                            class="btn btn-outline-success w-100 p-4 text-start hover-shadow bg-white">
                                            <div class="d-flex align-items-center"><i
                                                    class="bi bi-person-plus fs-1 me-3"></i>
                                                <div><span class="fw-bold fs-5 d-block">Nuevo Cliente</span><small
                                                        class="text-muted">Registrar nueva persona</small></div>
                                            </div>
                                        </a>
                                    </div>
                                </div>

                            </div>
                    </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
            // Datos desde el servidor
            const datosEstados = <%- JSON.stringify(graficos.estados) %>;
            const datosBalance = <%- JSON.stringify(graficos.balance) %>;
            const moneda = "<%= empresa.moneda %>";

            // 1. Gráfico: Estado de la Cartera
            const ctx1 = document.getElementById('chartEstados').getContext('2d');
            new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: ['Pendiente', 'Pagado', 'Vencido'],
                    datasets: [{
                        data: datosEstados,
                        backgroundColor: ['#ffc107', '#198754', '#dc3545'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            // 2. Gráfico: Balance (Prestado vs Recuperado)
            const ctx2 = document.getElementById('chartBalance').getContext('2d');
            new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['Total Prestado (Histórico)', 'Total Recuperado'],
                    datasets: [{
                        label: `Monto en ${moneda}`,
                        data: datosBalance,
                        backgroundColor: ['#0d6efd', '#0dcaf0'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        </script>

        <%- include('partials/footer') %>