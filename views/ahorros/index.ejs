<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('../partials/sidebar') %>

                    <div class="col py-0 py-md-3 main-content-wrapper">
                        <%- include('../partials/mobile-header') %>
                            <div class="container-fluid px-4 py-4">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h2>🐖 Cuentas de Ahorro</h2>
                                    <a href="/ahorros/aperturar" class="btn btn-primary">
                                        <i class="bi bi-plus-circle"></i> Aperturar Cuenta
                                    </a>
                                </div>

                                <% if(mensajeExito && mensajeExito.length> 0) { %>
                                    <div class="d-none" id="flashMessageSuccess">
                                        <%= mensajeExito %>
                                    </div>
                                    <% } %>

                                        <div class="card card-box p-3">
                                            <div class="table-responsive">
                                                <table class="table table-hover align-middle">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>ID Cuenta</th>
                                                            <th>Titular</th>
                                                            <th>CC</th>
                                                            <th class="text-end">Saldo Disponible</th>
                                                            <th class="text-center" style="width: 250px;">Meta de Ahorro</th>
                                                            <th>Acciones</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% if (cuentas.length> 0) { %>
                                                            <% cuentas.forEach(c=> { %>
                                                                <tr>
                                                                    <td><span class="badge bg-secondary">#<%= c.id %>
                                                                                </span></td>
                                                                    <td class="fw-bold">
                                                                        <%= c.nombre %>
                                                                            <%= c.apellido %>
                                                                    </td>
                                                                    <td>
                                                                        <%= c.dni %>
                                                                    </td>
                                                                    <td class="text-end fw-bold text-success fs-5">
                                                                        <%= empresa.moneda %>
                                                                            <%= formatCurrency(c.saldo_actual, 2) %>
                                                                    </td>
                                                                    <td class="text-center">
                                                                        <% if (c.meta_monto > 0) { 
                                                                            let porc = Math.min((c.saldo_actual / c.meta_monto) * 100, 100).toFixed(0);
                                                                            let colorClass = porc == 100 ? 'bg-success' : 'bg-primary';
                                                                        %>
                                                                            <div class="small mb-1 d-flex justify-content-between">
                                                                                <span class="text-truncate" style="max-width: 150px;"><%= c.meta_nombre || 'Meta' %></span>
                                                                                <span class="fw-bold"><%= porc %>%</span>
                                                                            </div>
                                                                            <div class="progress" style="height: 8px;">
                                                                                <div class="progress-bar <%= colorClass %>" role="progressbar" style="width: <%= porc %>%"></div>
                                                                            </div>
                                                                            <small class="text-muted" style="font-size: 0.7rem;">
                                                                                Meta: <%= empresa.moneda %> <%= formatCurrency(c.meta_monto, 0) %>
                                                                            </small>
                                                                        <% } else { %>
                                                                            <span class="text-muted small">Sin meta definida</span>
                                                                        <% } %>
                                                                    </td>
                                                                    <td>
                                                                        <a href="/ahorros/ver/<%= c.id %>"
                                                                            class="btn btn-sm btn-outline-primary">
                                                                            <i class="bi bi-arrow-left-right"></i>
                                                                            Operaciones
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="5" class="text-center py-5">No
                                                                                hay cuentas de ahorro activas.</td>
                                                                        </tr>
                                                                        <% } %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                            </div>
                    </div>
            </div>
        </div>
        <%- include('../partials/footer') %>
