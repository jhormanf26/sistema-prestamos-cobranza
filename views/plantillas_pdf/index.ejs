<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>
            
            <div class="col py-0 py-md-3 main-content-wrapper">
                <%- include('../partials/mobile-header') %>
                
                <div class="container-fluid px-4 py-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="h3"><i class="bi bi-file-earmark-pdf-fill text-danger"></i> Plantillas de Documentos PDF</h2>
                    </div>

                    <div class="alert alert-info border-0 shadow-sm mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Aquí puedes editar los textos legales, cláusulas y pies de página que aparecen en los documentos generados por el sistema.
                    </div>

                    <div class="row">
                        <% plantillas.forEach(p => { %>
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-header bg-white py-3 border-0">
                                        <div class="d-flex align-items-center mb-1">
                                            <div class="bg-danger bg-opacity-10 p-2 rounded me-3">
                                                <i class="bi bi-file-pdf text-danger fs-4"></i>
                                            </div>
                                            <h5 class="card-title mb-0 fw-bold"><%= p.nombre %></h5>
                                        </div>
                                    </div>
                                    <div class="card-body pt-0">
                                        <p class="text-muted small mb-4"><%= p.descripcion %></p>
                                        
                                        <div class="p-3 bg-light rounded border mb-4" style="height: 120px; overflow: hidden; font-size: 0.8rem; line-height: 1.4; color: #555;">
                                            <%= p.contenido.substring(0, 200) %>...
                                        </div>

                                        <div class="d-grid">
                                            <a href="/plantillas-pdf/editar/<%= p.slug %>" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-pencil-square me-2"></i> Editar Contenido
                                            </a>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-white border-0 text-center pb-3">
                                        <small class="text-muted">Última actualización: <%= new Date(p.updated_at).toLocaleDateString() %></small>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
