<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('../partials/sidebar') %>

                    <div class="col py-0 py-md-3 main-content-wrapper">
                        <%- include('../partials/mobile-header') %>
                            <div class="container-fluid px-4 py-4">

                                <h3 class="text-center text-secondary mb-4">Otorgar Nuevo Préstamo</h3>

                                <% if(mensajeError && mensajeError.length> 0) { %>
                                    <div class="alert alert-danger">
                                        <%= mensajeError %>
                                    </div>
                                    <% } %>

                                        <form action="/prestamos/guardar" method="POST" id="formPrestamo">
                                            <div class="row">

                                                <div class="col-md-8">
                                                    <div class="card card-box p-4 border-0 shadow-sm">
                                                        <h5 class="text-primary mb-3">Detalles Financieros</h5>

                                                        <div class="mb-3">
                                                            <label class="form-label fw-bold">Seleccionar
                                                                Cliente</label>
                                                            <select name="cliente_id" class="form-select" required>
                                                                <option value="">-- Buscador de Clientes --</option>
                                                                <% clientes.forEach(c=> { %>
                                                                    <option value="<%= c.id %>">
                                                                        <%= c.dni %> - <%= c.nombre %>
                                                                                <%= c.apellido %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select>
                                                        </div>

                                                        <div class="row">
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Monto a Prestar (<%=
                                                                        empresa.moneda %>)</label>
                                                                <input type="text" name="monto" id="inputMonto"
                                                                    class="form-control currency-input" required
                                                                    placeholder="0">
                                                            </div>
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Interés (%)</label>
                                                                <input type="number" step="0.01" name="interes"
                                                                    id="inputInteres" class="form-control" required
                                                                    placeholder="20">
                                                            </div>
                                                        </div>

                                                        <div class="row">
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Cantidad de Cuotas</label>
                                                                <input type="number" name="cuotas" id="inputCuotas"
                                                                    class="form-control" required value="1">
                                                            </div>
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Frecuencia de Pago</label>
                                                                <select name="frecuencia" class="form-select">
                                                                    <option value="diario">Diario</option>
                                                                    <option value="semanal">Semanal</option>
                                                                    <option value="quincenal">Quincenal</option>
                                                                    <option value="mensual" selected>Mensual</option>
                                                                </select>
                                                            </div>
                                                        </div>

                                                        <div class="mb-3">
                                                            <label class="form-label">Fecha de Inicio</label>
                                                            <input type="date" name="fecha_inicio" class="form-control"
                                                                required
                                                                value="<%= new Date().toISOString().split('T')[0] %>">
                                                        </div>

                                                        <div class="mb-3">
                                                            <label class="form-label">Observaciones</label>
                                                            <textarea name="observaciones" class="form-control" rows="3" placeholder="Notas adicionales sobre el préstamo..."></textarea>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-md-4">
                                                    <div class="card bg-dark text-white p-4 h-100 shadow-sm">
                                                        <h5 class="mb-4 border-bottom pb-2 text-white">Simulación</h5>

                                                        <div class="mb-4">
                                                            <small class="text-white-50">Monto Solicitado</small>
                                                            <h3 class="fw-bold text-primary" id="simMonto">
                                                                <%= empresa.moneda %> 0.00
                                                            </h3>
                                                        </div>

                                                        <div class="mb-4">
                                                            <small class="text-white-50">Interés Ganado</small>
                                                            <h3 class="fw-bold text-warning" id="simInteres">
                                                                <%= empresa.moneda %> 0.00
                                                            </h3>
                                                        </div>

                                                        <div class="mb-4">
                                                            <small class="text-white-50">Total a Devolver</small>
                                                            <h2 class="fw-bold text-success" id="simTotal">
                                                                <%= empresa.moneda %> 0.00
                                                            </h2>
                                                        </div>

                                                        <div class="mb-4">
                                                            <small class="text-white-50">Valor por Cuota</small>
                                                            <h3 class="fw-bold text-info" id="simCuota">
                                                                <%= empresa.moneda %> 0.00
                                                            </h3>
                                                        </div>

                                                        <div class="d-grid mt-auto">
                                                            <button type="submit"
                                                                class="btn btn-success btn-lg fw-bold">
                                                                Confirmar Préstamo
                                                            </button>
                                                            <a href="/prestamos"
                                                                class="btn btn-outline-light mt-2 btn-sm">Cancelar</a>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </form>

                            </div>
                    </div>
            </div>
        </div>

        <%- include('../partials/footer') %>

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const inputMonto = document.getElementById('inputMonto');
                    const inputInteres = document.getElementById('inputInteres');
                    const formPrestamo = document.getElementById('formPrestamo');

                    const simMonto = document.getElementById('simMonto');
                    const simInteres = document.getElementById('simInteres');
                    const simTotal = document.getElementById('simTotal');
                    const simCuota = document.getElementById('simCuota');
                    const inputCuotas = document.getElementById('inputCuotas');

                    // Obtenemos el símbolo de moneda desde el servidor
                    const moneda = "<%= empresa.moneda %>";

                    // Aplicamos la máscara de miles al input de monto
                    if (window.applyCurrencyMask) {
                        window.applyCurrencyMask('.currency-input');
                    }

                    // --- CAPTURA DE DATOS DESDE EL SIMULADOR ---
                    const urlParams = new URLSearchParams(window.location.search);
                    const pMonto = urlParams.get('monto');
                    const pInteres = urlParams.get('interes');
                    const pCuotas = urlParams.get('cuotas');
                    const pFrecuencia = urlParams.get('frecuencia');

                    if (pMonto) inputMonto.value = pMonto;
                    if (pInteres) inputInteres.value = pInteres;
                    if (pCuotas) inputCuotas.value = pCuotas;
                    if (pFrecuencia) document.querySelector('select[name="frecuencia"]').value = pFrecuencia;

                    // Si el monto fue seteado, disparamos el formateo
                    if (pMonto && window.applyCurrencyMask) {
                        const event = new Event('input', { bubbles: true });
                        inputMonto.dispatchEvent(event);
                    }
                    // ------------------------------------------

                    function calcular() {
                        // Obtenemos el valor limpio (solo números)
                        const rawValue = inputMonto.value.replace(/\D/g, '');
                        const m = parseFloat(rawValue) || 0;
                        const i = parseFloat(inputInteres.value) || 0;
                        const c = parseInt(inputCuotas.value) || 1;

                        const interesGanado = m * (i / 100);
                        const total = m + interesGanado;
                        const cuota = total / (c > 0 ? c : 1);

                        if (window.formatCurrency) {
                            simMonto.innerText = `${moneda} ${window.formatCurrency(m, 2)}`;
                            simInteres.innerText = `${moneda} ${window.formatCurrency(interesGanado, 2)}`;
                            simTotal.innerText = `${moneda} ${window.formatCurrency(total, 2)}`;
                            simCuota.innerText = `${moneda} ${window.formatCurrency(cuota, 2)}`;
                        } else {
                            simMonto.innerText = `${moneda} ${m.toFixed(2)}`;
                            simInteres.innerText = `${moneda} ${interesGanado.toFixed(2)}`;
                            simTotal.innerText = `${moneda} ${total.toFixed(2)}`;
                            simCuota.innerText = `${moneda} ${cuota.toFixed(2)}`;
                        }
                    }

                    // Escuchamos tanto el evento personalizado como el estándar
                    inputMonto.addEventListener('moneyInput', calcular);
                    inputMonto.addEventListener('input', calcular);

                    inputInteres.addEventListener('input', calcular);
                    inputCuotas.addEventListener('input', calcular);

                    // LIMPIAR PUNTOS ANTES DE ENVIAR AL SERVIDOR
                    if (formPrestamo) {
                        formPrestamo.addEventListener('submit', function () {
                            inputMonto.value = inputMonto.value.replace(/\D/g, ''); // Deja solo números
                        });
                    }

                    // Ejecutar cálculo inicial
                    calcular();
                });
            </script>