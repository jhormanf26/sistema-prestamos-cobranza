<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<style>
    /* Solo para los encabezados ordenables */
    th.sortable-header { 
        padding: 0 !important; 
        transition: background-color 0.2s;
    }
    th.sortable-header a { 
        display: flex; 
        align-items: center; 
        justify-content: space-between;
        padding: 0.75rem; 
        text-decoration: none; 
        color: #444; 
        width: 100%;
        height: 100%;
    }
    th.sortable-header a:hover { background-color: #f8f9fa; color: #0d6efd; }
    th.sortable-header i { font-size: 0.7rem; margin-left: 5px; color: #ccc; }
    th.sortable-header.active i { color: #0d6efd; opacity: 1; }
    th.sortable-header.active { border-bottom: 2px solid #0d6efd; background-color: #f0f7ff; }

    /* Estilos para botones de acción compactos */
    .btn-xs {
        padding: 0.15rem 0.35rem;
        font-size: 0.75rem;
        line-height: 1.2;
        border-radius: 4px;
    }
    .main-content-wrapper .table td {
        vertical-align: middle;
        padding-top: 12px;
        padding-bottom: 12px;
    }
</style>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>
            
            <div class="col py-0 py-md-3 main-content-wrapper">
                <%- include('../partials/mobile-header') %>
                
                <div class="container-fluid px-4 py-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                        <h2>💰 Gestión de Préstamos</h2>
                        
                        <div class="d-flex gap-2">
                            <a href="/reportes/excel/prestamos" class="btn btn-success">
                                <i class="bi bi-file-earmark-spreadsheet"></i> Exportar Excel
                            </a>
                            <a href="/prestamos/crear" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Nuevo Préstamo
                            </a>
                        </div>
                    </div>

                    <% if(mensajeExito && mensajeExito.length > 0) { %>
                        <div class="d-none" id="flashMessageSuccess"><%= mensajeExito %></div>
                    <% } %>
                    <% if(mensajeError && mensajeError.length > 0) { %>
                        <div class="d-none" id="flashMessageError"><%= mensajeError %></div>
                    <% } %>

                    <div class="card card-box p-3 mb-4 bg-light">
                        <form action="/prestamos" method="GET" class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label class="col-form-label fw-bold"><i class="bi bi-search"></i> Buscar:</label>
                            </div>
                            <div class="col-auto flex-grow-1">
                                <input type="text" name="q" class="form-control" placeholder="Nombre de Cliente o ID Préstamo..." value="<%= busqueda %>">
                                <input type="hidden" name="sort" value="<%= sort %>">
                                <input type="hidden" name="order" value="<%= order %>">
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-dark">Filtrar</button>
                                <% if(busqueda) { %>
                                    <a href="/prestamos" class="btn btn-outline-secondary">Limpiar</a>
                                <% } %>
                            </div>
                        </form>
                    </div>

                    <div class="card card-box p-3">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <!-- SOLO MODIFICAMOS EL ENCABEZADO -->
                                        <th class="sortable-header <%= sort === 'id' ? 'active' : '' %>">
                                            <a href="/prestamos?q=<%= busqueda %>&sort=id&order=<%= sort === 'id' && order === 'asc' ? 'desc' : 'asc' %>">
                                                ID <i class="bi <%= sort === 'id' ? (order === 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-down' %>"></i>
                                            </a>
                                        </th>
                                        <th class="sortable-header <%= sort === 'nombre' ? 'active' : '' %>">
                                            <a href="/prestamos?q=<%= busqueda %>&sort=nombre&order=<%= sort === 'nombre' && order === 'asc' ? 'desc' : 'asc' %>">
                                                Cliente <i class="bi <%= sort === 'nombre' ? (order === 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-down' %>"></i>
                                            </a>
                                        </th>
                                        <th class="sortable-header <%= sort === 'monto_total' ? 'active' : '' %>">
                                            <a href="/prestamos?q=<%= busqueda %>&sort=monto_total&order=<%= sort === 'monto_total' && order === 'asc' ? 'desc' : 'asc' %>">
                                                Total a Pagar <i class="bi <%= sort === 'monto_total' ? (order === 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-down' %>"></i>
                                            </a>
                                        </th>
                                        <th>Observaciones</th>
                                        <th class="sortable-header <%= sort === 'estado' ? 'active' : '' %>">
                                            <a href="/prestamos?q=<%= busqueda %>&sort=estado&order=<%= sort === 'estado' && order === 'asc' ? 'desc' : 'asc' %>">
                                                Estado <i class="bi <%= sort === 'estado' ? (order === 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-down' %>"></i>
                                            </a>
                                        </th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (prestamos.length > 0) { %>
                                        <% prestamos.forEach(p => { %>
                                            <tr>
                                                <td><span class="badge bg-secondary">#<%= p.id %></span></td>
                                                <td>
                                                    <div class="fw-bold"><%= p.nombre %> <%= p.apellido %></div>
                                                    <small class="text-muted">CC: <%= p.dni %></small>
                                                </td>
                                                <td class="text-success fw-bold">
                                                    <%= empresa.moneda %> <%= formatCurrency(p.monto_total, 2) %>
                                                </td>
                                                <td class="text-muted small">
                                                    <%= p.observaciones && p.observaciones.trim() !== '' ? p.observaciones : '--' %>
                                                </td>
                                                <td>
                                                    <% if(p.estado == 'pendiente') { %>
                                                        <span class="badge bg-primary">Por Cobrar</span>
                                                    <% } else if(p.estado == 'pagado') { %>
                                                        <span class="badge bg-success">Pagado</span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger">Vencido</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <div class="row g-1">
                                                        <div class="col-6">
                                                            <div class="btn-group w-100" role="group">
                                                                <a href="/reportes/ticket-desembolso/<%= p.id %>" target="_blank" class="btn btn-xs btn-dark" title="Ticket Desembolso">
                                                                    <i class="bi bi-receipt"></i>
                                                                </a>
                                                                <a href="/reportes/contrato/<%= p.id %>" target="_blank" class="btn btn-xs btn-outline-danger" title="Contrato">
                                                                    <i class="bi bi-file-earmark-pdf"></i>
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <div class="col-6">
                                                            <div class="btn-group w-100" role="group">
                                                                <a href="/prestamos/cronograma/<%= p.id %>" class="btn btn-xs btn-outline-primary" title="Ver Cuotas">
                                                                    <i class="bi bi-calendar-week"></i>
                                                                </a>
                                                                <a href="/reportes/cronograma-pdf/<%= p.id %>" target="_blank" class="btn btn-xs btn-primary" title="Descargar Cronograma">
                                                                    <i class="bi bi-download"></i>
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <div class="col-12 mt-1">
                                                            <div class="btn-group w-100" role="group">
                                                                <% if(p.estado != 'pagado') { %>
                                                                    <a href="/pagos/registrar/<%= p.id %>" class="btn btn-sm btn-success py-1" title="Registrar Pago">
                                                                        <i class="bi bi-cash-coin"></i> Pago
                                                                    </a>
                                                                <% } %>
                                                                <a href="/reportes/estado-cuenta/<%= p.cliente_id %>" target="_blank" class="btn btn-sm btn-outline-info py-1" title="Estado de Cuenta Cliente">
                                                                    <i class="bi bi-person-lines-fill"></i> Estado
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="6" class="text-center py-5 text-muted">No se encontraron préstamos registrados.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                        
                        <% if (totalPages > 1) { %>
                            <nav class="mt-4 d-flex justify-content-between align-items-center">
                                <small class="text-muted">Página <%= currentPage %> de <%= totalPages %></small>
                                <ul class="pagination mb-0">
                                    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="/prestamos?page=<%= currentPage - 1 %>&q=<%= busqueda %>&sort=<%= sort %>&order=<%= order %>">Anterior</a>
                                    </li>
                                    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="/prestamos?page=<%= currentPage + 1 %>&q=<%= busqueda %>&sort=<%= sort %>&order=<%= order %>">Siguiente</a>
                                    </li>
                                </ul>
                            </nav>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include('../partials/footer') %>