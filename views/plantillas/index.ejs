<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>
            
            <div class="col py-0 py-md-3 main-content-wrapper">
                <%- include('../partials/mobile-header') %>
                
                <div class="container-fluid px-4 py-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="h3"><i class="bi bi-envelope-paper-fill text-primary"></i> Gestión de Plantillas</h2>
                    </div>

                    <div class="row">
                        <% plantillas.forEach(p => { %>
                            <div class="col-md-6 mb-4">
                                <div class="card shadow-sm border-0 h-100 p-2">
                                    <div class="card-header bg-white py-3 border-0">
                                        <h5 class="card-title mb-0 fw-bold"><%= p.nombre %></h5>
                                        <small class="text-muted"><%= p.descripcion %></small>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3 small">
                                            <strong>Asunto:</strong> <%= p.asunto %>
                                        </div>
                                        <div class="mb-3">
                                            <span class="badge bg-light text-dark p-2 border" style="font-size: 0.75rem;">
                                                Tags: <%= p.variables_disponibles %>
                                            </span>
                                        </div>
                                        
                                        <div class="border rounded bg-light mb-3" style="height: 180px; overflow: hidden; position: relative; border-style: dashed !important;">
                                            <iframe src="/plantillas/preview/<%= p.slug %>" style="width: 150%; height: 250px; border: none; transform: scale(0.66); transform-origin: 0 0;"></iframe>
                                            <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: transparent;"></div>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <a href="/plantillas/editar/<%= p.slug %>" class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square me-2"></i> Editar Diseño y Contenido
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
